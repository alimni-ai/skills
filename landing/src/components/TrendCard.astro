---
import type { Tool } from '../data/tools';
import { categoryMeta } from '../data/tools';
import StatusBadge from './StatusBadge.astro';

interface Props {
  tool: Tool;
  variant?: 'compact' | 'full';
}

const { tool, variant = 'compact' } = Astro.props;
const category = categoryMeta[tool.category];

// CTA channels — phase 1 deterministic (no LLM/HITL) per Wissam rollout-4-phases.
// Telegram is the AR-MENA-friendly alternative to mailto (lower friction on mobile).
const mailto = `mailto:hello@alimni-ai.com?subject=${encodeURIComponent(`[Alimni] طلب شرح ${tool.name_en}`)}&body=${encodeURIComponent(`السلام عليكم،\n\nأطلب شرحًا تفصيليًّا بالعربيّة لأداة "${tool.name_en}".\n\nما الذي يهمّني خصّيصًا:\n- \n\nشكرًا.`)}`;
const telegram = 'https://t.me/alimni_ar';
---
<article class={`trend-card trend-card--${variant} trend-card--${tool.status}`}>
  <header class="trend-card__header">
    <span class="trend-card__icon" aria-hidden="true">{tool.icon}</span>
    <div class="trend-card__title-block">
      <h3 class="trend-card__title">
        {variant === 'compact' ? (
          <a class="trend-card__title-link" href={`/tools/${tool.slug}/`}>{tool.name_ar}</a>
        ) : (
          tool.name_ar
        )}
      </h3>
      <p class="trend-card__category">
        <span class="trend-card__category-ar">{category.ar}</span>
        <span class="trend-card__category-sep" aria-hidden="true">·</span>
        <span class="trend-card__category-en latin">{category.en}</span>
      </p>
    </div>
    <div class="trend-card__status-block">
      <StatusBadge status={tool.status} size={variant === 'compact' ? 'sm' : 'md'} />
      {tool.eta_label && (
        <span class="trend-card__eta" aria-label={`موعد متوقّع : ${tool.eta_label}`}>
          <span class="trend-card__eta-arrow" aria-hidden="true">←</span>
          <span class="trend-card__eta-text">{tool.eta_label}</span>
        </span>
      )}
    </div>
  </header>

  {variant === 'compact' && (
    <p class="trend-card__why">{tool.why_ar}</p>
  )}

  {variant === 'full' && (
    <div class="trend-card__body">
      <section>
        <h4>لماذا هذه الأداة مهمّة؟</h4>
        <p>{tool.why_ar}</p>
      </section>
      <section>
        <h4>لمن هذه الأداة؟</h4>
        <p>{tool.audience_ar}</p>
      </section>
      <section>
        <h4>ماذا يمكنك أن تبني بها؟</h4>
        <p>{tool.build_ar}</p>
      </section>
    </div>
  )}

  <footer class="trend-card__footer">
    <div class="trend-card__cta-row">
      <a class="trend-card__cta trend-card__cta--primary" href={telegram} target="_blank" rel="noopener">
        <span class="trend-card__cta-icon" aria-hidden="true">✉</span>
        <span class="trend-card__cta-ar">اطلب على تيليجرام</span>
      </a>
      <a class="trend-card__cta trend-card__cta--secondary latin" href={mailto}>
        <span class="trend-card__cta-icon" aria-hidden="true">@</span>
        <span class="trend-card__cta-ar">بريد</span>
      </a>
    </div>
    <a class="trend-card__source latin" href={tool.source_url} target="_blank" rel="noopener">
      <small>المصدر · {tool.source_label} ↗</small>
    </a>
  </footer>
</article>

<style>
  .trend-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: var(--s-md);
    display: flex;
    flex-direction: column;
    gap: var(--s-sm);
    transition: border-color 120ms ease, transform 120ms ease;
  }

  .trend-card:hover { border-color: var(--accent-dim); transform: translateY(-1px); }

  /* status accent — top border progression mirrors ladder pattern */
  .trend-card--ready    { border-block-start: 2px solid var(--accent-bright); }
  .trend-card--wip      { border-block-start: 2px solid var(--accent-dim); }
  .trend-card--requested { border-block-start: 2px solid var(--line-strong); }

  .trend-card--full {
    padding: var(--s-lg);
    gap: var(--s-md);
  }

  /* ── Header ── */
  /* Compact (default): column-stacked centered, like ladder cards.
     Avoids horizontal squeeze when the grid cell is narrow (~300px). */
  .trend-card__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-xs);
    text-align: center;
  }

  /* Full (page dédiée) : horizontal row, more breathing room */
  .trend-card--full .trend-card__header {
    flex-direction: row;
    align-items: center;
    gap: var(--s-md);
    text-align: start;
    flex-wrap: wrap;
  }

  .trend-card__icon {
    font-size: 2rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .trend-card--full .trend-card__icon { font-size: 2.5rem; }

  .trend-card__title-block {
    /* compact: takes natural width, centered */
  }

  .trend-card--full .trend-card__title-block {
    flex: 1;
    min-width: 0;
  }

  .trend-card__title {
    font-family: var(--font-ar);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    line-height: 1.3;
  }

  /* Title link — wraps the AR title only, leaves CTAs/source as separate
     `<a>` (avoids the HTML5 invalid nested-anchor anti-pattern). */
  .trend-card__title-link {
    color: inherit;
    text-decoration: none;
    border-block-end: 1px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .trend-card__title-link:hover,
  .trend-card__title-link:focus-visible {
    color: var(--accent-bright);
    border-block-end-color: var(--accent-dim);
  }

  .trend-card--full .trend-card__title { font-size: 1.5rem; }

  /* Status block — pill badge + optional eta_label hint underneath
     (per Ines critique #7 2026-05-07 : signal "roadmap maîtrisée" vs
     "catalog vide" when many tools share the same status). */
  .trend-card__status-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .trend-card--full .trend-card__status-block { align-items: flex-start; }

  .trend-card__eta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    color: var(--fg-muted);
    direction: rtl;
  }

  .trend-card__eta-arrow {
    color: var(--accent-dim);
    font-family: var(--font-mono);
    line-height: 1;
  }

  .trend-card__eta-text { font-family: var(--font-ar); }

  /* Category label : taxonomy hint per Ines critique 2026-05-07
     (agents/orchestration/automation/protocol must not be mixed visually). */
  .trend-card__category {
    margin: 0;
    font-size: 0.7rem;
    color: var(--fg-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    direction: ltr;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
  }

  .trend-card--full .trend-card__category {
    font-size: 0.8rem;
  }

  .trend-card__category-ar {
    font-family: var(--font-ar);
    text-transform: none;
    letter-spacing: 0;
  }

  .trend-card__category-sep { color: var(--accent-dim); }
  .trend-card__category-en { color: var(--fg-muted); }

  /* ── Body ── */
  .trend-card__why {
    color: var(--fg-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    text-align: center;
  }

  .trend-card--full .trend-card__why { text-align: start; }

  .trend-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--s-md);
  }

  /* Override the global `section { padding-block: 4-6rem }` rule from
     global.css (intended for top-level page sections). Inside the card,
     these <section> elements are content groups, not page sections. */
  .trend-card__body section {
    display: flex;
    flex-direction: column;
    gap: var(--s-xs);
    padding-block: 0;
  }
  .trend-card__body h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: none;
    margin: 0;
  }
  .trend-card__body p {
    color: var(--fg);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Footer ── */
  .trend-card__footer {
    margin-block-start: auto;
    padding-block-start: var(--s-sm);
    border-block-start: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-xs);
  }

  .trend-card--full .trend-card__footer { align-items: flex-start; }

  /* CTA row : 2 channels per Ines critique (mailto alone too high friction
     on MENA mobile). Telegram primary, mailto secondary. */
  .trend-card__cta-row {
    display: flex;
    gap: var(--s-sm);
    direction: rtl;
    flex-wrap: wrap;
  }

  .trend-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    border-radius: 4px;
    font-size: 0.8rem;
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
  }

  .trend-card__cta--primary {
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
    font-weight: 500;
  }
  .trend-card__cta--primary:hover {
    background: var(--accent-bright);
    border-color: var(--accent-bright);
    color: var(--bg);
  }

  .trend-card__cta--secondary {
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--line-strong);
  }
  .trend-card__cta--secondary:hover {
    color: var(--fg);
    border-color: var(--accent-dim);
  }

  .trend-card__cta-ar { font-family: var(--font-ar); }
  .trend-card__cta-icon { font-family: var(--font-mono); font-size: 0.95em; line-height: 1; }

  .trend-card__source {
    color: var(--fg-muted);
    font-size: 0.75rem;
    direction: ltr;
    text-decoration: none;
  }
  .trend-card__source:hover { color: var(--fg); }

  @media (max-width: 540px) {
    .trend-card__title-en { display: none; }
  }
</style>
