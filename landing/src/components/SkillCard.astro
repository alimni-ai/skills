---
import MaturityBadge from './MaturityBadge.astro';

interface Props {
  number: number;
  slug: string;
  title_ar: string;
  description_ar: string;
  est_runtime_min: number;
  maturity: 'mve-partial' | 'mve-complete' | 'mature' | 'reference' | 'planned';
  variant?: 'core' | 'ext';
  github_url?: string;
  install_cmd_claude?: string;
  install_cmd_codex?: string;
}

const {
  number,
  slug,
  title_ar,
  description_ar,
  est_runtime_min,
  maturity,
  variant = 'core',
  github_url = `https://github.com/alimni-ai/skills/tree/main/skills/${slug}`,
  install_cmd_claude = `claude plugin install alimni-ai/skills/${slug}`,
  install_cmd_codex = `codex skill add alimni-ai/skills/${slug}`
} = Astro.props;

const isPlanned = maturity === 'planned';
const isShipped = maturity === 'mve-complete' || maturity === 'mature' || maturity === 'reference';
---
<article class={`skill-card skill-card--${variant} ${isShipped ? 'shipped' : 'pending'}`}>
  <header class="skill-card__header">
    <div class="skill-number latin">{`#${number.toString().padStart(2, '0')}`}</div>
    <MaturityBadge stage={maturity} size="sm" />
  </header>

  <h3 class="skill-card__title">{title_ar}</h3>
  <p class="skill-card__description">{description_ar}</p>

  <div class="skill-card__meta">
    <small class="latin">
      <code>{slug}</code> · ~{est_runtime_min} min
    </small>
  </div>

  {!isPlanned && (
    <div class="skill-card__install">
      <details>
        <summary class="latin">Install ↗</summary>
        <div class="install-block">
          <small>Claude Code</small>
          <pre><code class="latin">{install_cmd_claude}</code></pre>
          <small>OpenAI Codex</small>
          <pre><code class="latin">{install_cmd_codex}</code></pre>
        </div>
      </details>
    </div>
  )}

  {isPlanned && (
    <p class="skill-card__pending muted">قريبًا · <span class="latin">Coming soon</span></p>
  )}

  <a href={github_url} class="skill-card__link latin" target="_blank" rel="noopener">
    GitHub →
  </a>
</article>

<style>
  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: var(--s-lg);
    display: flex;
    flex-direction: column;
    gap: var(--s-sm);
    transition: border-color 120ms ease, transform 120ms ease;
  }

  .skill-card.shipped { border-color: var(--accent-dim); }
  .skill-card.shipped:hover { border-color: var(--accent); transform: translateY(-2px); }
  .skill-card.pending { opacity: 0.85; }

  /* ── Variant: core (main curriculum) ── */
  .skill-card--core { /* default size */ }

  /* ── Variant: ext (extensions, secondary) ── */
  .skill-card--ext {
    padding: var(--s-md);
    background: transparent;
    gap: var(--s-xs);
  }
  .skill-card--ext .skill-card__title { font-size: 1.1rem; }
  .skill-card--ext .skill-card__description { font-size: 0.9rem; }
  .skill-card--ext .skill-card__install { display: none; }
  .skill-card--ext .skill-card__link { font-size: 0.78rem; }
  .skill-card--ext.pending { opacity: 0.7; }

  .skill-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    direction: ltr;
    gap: var(--s-sm);
    flex-wrap: wrap;
  }

  .skill-number {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-muted);
    letter-spacing: 0.05em;
  }

  .skill-card--core .skill-number {
    font-size: 1rem;
    color: var(--accent);
  }

  .skill-card__title {
    font-family: var(--font-ar);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--fg);
    margin-block-end: 0;
  }

  .skill-card__description {
    color: var(--fg-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .skill-card__meta {
    margin-block-start: var(--s-xs);
    direction: ltr;
    text-align: left;
  }

  .skill-card__install summary {
    cursor: pointer;
    color: var(--accent);
    font-size: 0.85rem;
    user-select: none;
    list-style: none;
  }

  .skill-card__install summary::-webkit-details-marker { display: none; }
  .skill-card__install summary:hover { color: var(--accent-bright); }

  .install-block { margin-block-start: var(--s-sm); }
  .install-block small { font-size: 0.75rem; color: var(--fg-muted); display: block; margin-block-start: var(--s-sm); }
  .install-block pre { font-size: 0.8rem; padding: 0.6rem; margin-block-start: var(--s-xs); white-space: pre-wrap; word-break: break-all; }

  .skill-card__pending {
    direction: ltr;
    text-align: left;
    font-size: 0.9rem;
  }

  .skill-card__link {
    margin-block-start: auto;
    padding-block-start: var(--s-sm);
    font-size: 0.85rem;
    border-block-start: 1px solid var(--line);
    align-self: flex-start;
    direction: ltr;
  }

  /* Mobile: header stacks to avoid badge overflow */
  @media (max-width: 540px) {
    .skill-card__header { flex-direction: row; }
    .skill-card { padding: var(--s-md); }
    .skill-card__title { font-size: 1.2rem; }
  }
</style>
