---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrendCard from '../../components/TrendCard.astro';
import { tools } from '../../data/tools';

export function getStaticPaths() {
  return tools.map(tool => ({ params: { slug: tool.slug }, props: { tool } }));
}

const { tool } = Astro.props;

const title = `${tool.name_en} — Alimni AI · علّمني`;
const description = `${tool.name_en} : ${tool.why_ar}`;
---
<BaseLayout title={title} description={description}>
  <main class="tool-page">
    <nav class="tool-page__crumbs">
      <a href="/" class="latin">← الرئيسيّة · Home</a>
    </nav>

    <article class="tool-page__container container">
      <TrendCard tool={tool} variant="full" />

      <section class="tool-page__notice">
        <p class="muted">
          هذه صفحة <strong>تعريفيّة (المستوى ١)</strong>. الدليل التفصيليّ بالعربيّة (التثبيت، الأوامر، الأخطاء الشائعة، المختبر العمليّ) قيد الإعداد.
        </p>
        <p class="muted latin"><small>
          This is a Level 1 Trend Page. The full Arabic guide
          (install / commands / errors / lab) is in preparation.
          Use the request button on the card to prioritise this tool.
        </small></p>
      </section>

      <section class="tool-page__back">
        <a href="/#tools" class="btn">→ كلّ الأدوات · <span class="latin">All tools</span></a>
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .tool-page {
    padding-block: var(--s-2xl) var(--s-3xl);
  }

  .tool-page__crumbs {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--s-md);
    margin-block-end: var(--s-lg);
  }

  .tool-page__crumbs a {
    color: var(--fg-muted);
    font-size: 0.85rem;
    text-decoration: none;
  }
  .tool-page__crumbs a:hover { color: var(--accent); }

  .tool-page__container {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--s-xl);
  }

  .tool-page__notice {
    padding: var(--s-md);
    background: var(--bg-elevated);
    border: 1px dashed var(--line-strong);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: var(--s-sm);
  }

  .tool-page__notice p { margin: 0; }

  .tool-page__back {
    display: flex;
    justify-content: center;
  }
</style>
