---
import { readdirSync, statSync, readFileSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import matter from 'gray-matter';
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillCard from '../components/SkillCard.astro';
import RequestSkill from '../components/RequestSkill.astro';

// ── Read skills from ../../skills/<slug>/source.md ────────────────────────
// Single source of truth: source.md frontmatter drives both the build pipeline
// AND the landing display. When a skill graduates from 🌱 → 🌿 → 🌳, the
// landing reflects it automatically without any landing-side edit.

const SKILLS_DIR = join(process.cwd(), '..', 'skills');

// V1 curriculum order locked from spec §5
// Split: core path (1-3, MVE-complete cibles) vs extensions (4-5, MVE-partial cibles)
const V1_CORE = [
  'setup-agentic-ar',
  'prompt-loop-ar',
  'ship-real-product-ar'
];

const V1_EXTENSIONS = [
  'repo-to-agent-ar',
  'n8n-mcp-pipeline-ar'
];

const V1_ORDER = [...V1_CORE, ...V1_EXTENSIONS];

const V1_PLANNED_DEFAULTS: Record<string, { title_ar: string; description_ar: string; est_runtime_min: number }> = {
  'setup-agentic-ar':     { title_ar: 'إعداد بيئة الذكاء الاصطناعي الوكيل', description_ar: 'تثبيت Claude Code وCodex، أوّل برومبت، وحلّ مشاكل البيئة (مدخل عربي)',         est_runtime_min: 30 },
  'prompt-loop-ar':       { title_ar: 'حلقة البرومبت الاحترافيّة',         description_ar: 'الانعكاس المهني: prompt → run → read → debug → re-prompt — مع أمثلة عربية',          est_runtime_min: 45 },
  'ship-real-product-ar': { title_ar: 'إطلاق منتج حقيقي من الصفر',         description_ar: 'فكرة → repo → بناء بمساعدة الوكيل → نشر منتج (CRUD صغير على Vercel/Caddy)',         est_runtime_min: 120 },
  'repo-to-agent-ar':     { title_ar: 'وكيل على مستودعك الحقيقي',           description_ar: 'وصل الوكيل بمستودع برمجي قائم: Claude Code، MCP file system، أنماط مراجعة الكود',  est_runtime_min: 60 },
  'n8n-mcp-pipeline-ar':  { title_ar: 'أتمتة العمل عبر MCP وn8n',           description_ar: 'الأتمتة الذكية: التقاط → ترجمة → نشر — المهارة الفوقيّة (أتمتة الأكاديمية ذاتها)', est_runtime_min: 90 }
};

interface SkillData {
  number: number;
  slug: string;
  title_ar: string;
  description_ar: string;
  est_runtime_min: number;
  maturity: 'mve-partial' | 'mve-complete' | 'mature' | 'reference' | 'planned';
}

const skills: SkillData[] = V1_ORDER.map((slug, idx) => {
  const sourceFile = join(SKILLS_DIR, slug, 'source.md');
  const defaults = V1_PLANNED_DEFAULTS[slug] || { title_ar: slug, description_ar: '', est_runtime_min: 0 };

  if (!existsSync(sourceFile)) {
    return { number: idx + 1, slug, ...defaults, maturity: 'planned' as const };
  }

  const { data } = matter(readFileSync(sourceFile, 'utf8'));
  // Fallback to defaults if scaffold has TODO markers in title/desc
  const title_ar = data.title_ar?.startsWith('TODO') ? defaults.title_ar : (data.title_ar || defaults.title_ar);
  const description_ar = data.description_ar?.startsWith('TODO') ? defaults.description_ar : (data.description_ar || defaults.description_ar);

  return {
    number: idx + 1,
    slug,
    title_ar,
    description_ar,
    est_runtime_min: data.est_runtime_min || defaults.est_runtime_min,
    maturity: data.maturity || 'planned'
  };
});

const coreSkills = skills.filter(s => V1_CORE.includes(s.slug));
const extensionSkills = skills.filter(s => V1_EXTENSIONS.includes(s.slug));

// Counts for the maturity ladder section
const counts = {
  mveComplete: skills.filter(s => ['mve-complete', 'mature', 'reference'].includes(s.maturity)).length,
  mvePartial:  skills.filter(s => s.maturity === 'mve-partial').length,
  planned:     skills.filter(s => s.maturity === 'planned').length
};
---
<BaseLayout
  title="AI علّمني — Alimni AI · Arabic AI Engineering Academy"
  description="تعلّم الذكاء الاصطناعي بالممارسة، لا بالمشاهدة فقط. Agentic execution in Arabic, across tools."
>
  <main>
  <!-- ── Hero ───────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <!-- Brand mark — AR-script master with "AI" prefix (unified Amiri serif), Latin sub-mark discret -->
      <div class="brand-mark">
        <h1 class="ar-script hero-mark" aria-label="AI Alimni — Alimni AI">AI&nbsp;علّمني</h1>
        <p class="sub-mark latin"><span class="sub-mark-dot">·</span> Alimni AI</p>
      </div>

      <p class="hero-tagline-ar">علّمني الذكاء الاصطناعي بالعربية</p>

      <p class="hero-sub-ar">
        طبقة تنفيذ بالعربية لأدوات الذكاء الاصطناعي الوكيل،
        عبر <strong>Claude&nbsp;Code</strong> و<strong>Codex</strong> و<strong>n8n</strong> و<strong>MCP</strong>.
      </p>

      <!-- Dopamine block C1 — proof of execution, not just promise -->
      <div class="proof-block" aria-labelledby="proof-label">
        <p id="proof-label" class="proof-label-ar">
          في ٣٠ دقيقة، تنشر أوّل وكيل حقيقي
          <span class="proof-label-en latin">— ship your first agent in 30 min.</span>
        </p>

        <div class="proof-flow" role="list" aria-label="Path: install, run, publish">
          <span class="proof-step" role="listitem">
            <span class="proof-step-icon" aria-hidden="true">⚙️</span>
            <span class="proof-step-ar">تثبيت</span>
            <span class="proof-step-en latin">install</span>
          </span>
          <span class="proof-arrow" aria-hidden="true">←</span>
          <span class="proof-step" role="listitem">
            <span class="proof-step-icon" aria-hidden="true">▶️</span>
            <span class="proof-step-ar">تشغيل</span>
            <span class="proof-step-en latin">run</span>
          </span>
          <span class="proof-arrow" aria-hidden="true">←</span>
          <span class="proof-step is-published" role="listitem">
            <span class="proof-step-icon" aria-hidden="true">📦</span>
            <span class="proof-step-ar">نشر</span>
            <span class="proof-step-en latin">publish</span>
          </span>
        </div>

        <pre class="proof-terminal latin" aria-label="Example workflow"><code><span class="t-prompt">$</span> claude plugin install <span class="t-token">alimni-ai/setup-agentic-ar</span>
<span class="t-ok">✓</span> Environment ready  <span class="t-muted">·  بيئة جاهزة</span>
<span class="t-arrow">→</span> github.com/<span class="t-token">&lt;you&gt;</span>/first-agent</code></pre>
      </div>

      <div class="hero-cta">
        <a href="#skills" class="btn btn-primary">
          ابدأ المسار <span class="latin">· Start the path</span>
        </a>
        <a href="https://github.com/alimni-ai/skills" class="btn btn-ghost latin" target="_blank" rel="noopener">
          GitHub →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Why ─────────────────────────────────────────────────────────── -->
  <section class="why">
    <div class="container prose why-prose">
      <h2>لماذا علّمني؟</h2>

      <p>
        مئات الملايين من الناطقين بالعربية خارج ثورة الوكلاء الذكيين
        لأنّ معظم التعليم العملي للذكاء الاصطناعي ما يزال موجّهًا للإنجليزية.
      </p>

      <p class="why-aside">الترجمة وحدها ليست ميزة.</p>

      <p>ميزة <strong>علّمني</strong> هي:</p>
      <ul class="why-edge-list">
        <li>الاختيار،</li>
        <li>التنفيذ،</li>
        <li>الشرح،</li>
        <li>التطبيق العملي،</li>
        <li>الأدوات القابلة للتشغيل،</li>
        <li>والمجتمع.</li>
      </ul>

      <p class="why-closing">
        نحن لا نبني منصة دروس تقليدية،<br />
        بل نبني <strong>منظومة تنفيذ للذكاء الاصطناعي باللغة العربية</strong>.
      </p>

      <!-- EN secondary block, desktop only (AR-monolingual primary on mobile) -->
      <div class="why-en muted latin hide-on-mobile">
        <p>
          200M+ Arabic speakers are excluded from the AI-agent revolution
          because most practical AI education is still English-first.
        </p>

        <p class="why-aside">Translation alone is a commodity.</p>

        <p>Alimni AI's edge is not translation — it is:</p>
        <ul class="why-edge-list">
          <li>curation,</li>
          <li>execution,</li>
          <li>pedagogy,</li>
          <li>feedback loops,</li>
          <li>installable artifacts,</li>
          <li>and community.</li>
        </ul>

        <p class="why-closing">
          We are building<br />
          <strong>an Arabic AI execution ecosystem, not a passive course platform</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Maturity ladder ────────────────────────────────────────────── -->
  <!--
    Card IS the stage (no nested pill badge). Vertical layout: step number,
    big icon anchor, AR title, EN code, separator, description. Top-border
    accent darkens progressively (line → accent-dim → accent → accent-bright)
    to communicate maturation visually.
  -->
  <section class="ladder">
    <div class="container prose">
      <h2>سلّم النضج</h2>
      <p class="muted">
        كلّ مهارة تتدرّج عبر ٤ مراحل، كلّ مرحلة لها معيار صارم.
        لا نخفي ما لم يكتمل.
      </p>

      <ol class="ladder-grid" aria-label="Maturity stages, ascending">
        <li class="ladder-stage ladder-stage--mve-partial">
          <span class="ladder-stage__step latin" aria-hidden="true">01</span>
          <span class="ladder-stage__icon" aria-hidden="true">🌱</span>
          <p class="ladder-stage__title-ar">مبدئي</p>
          <p class="ladder-stage__title-en latin">MVE-partial</p>
          <p class="ladder-stage__desc">قابلة للتثبيت والتشغيل. تجمع أوّل التغذية الراجعة.</p>
        </li>
        <li class="ladder-stage ladder-stage--mve-complete">
          <span class="ladder-stage__step latin" aria-hidden="true">02</span>
          <span class="ladder-stage__icon" aria-hidden="true">🌿</span>
          <p class="ladder-stage__title-ar">مكتمل</p>
          <p class="ladder-stage__title-en latin">MVE-complete</p>
          <p class="ladder-stage__desc">مختبرة على Claude Code وCodex. مسار تنفيذ كامل.</p>
        </li>
        <li class="ladder-stage ladder-stage--mature">
          <span class="ladder-stage__step latin" aria-hidden="true">03</span>
          <span class="ladder-stage__icon" aria-hidden="true">🌳</span>
          <p class="ladder-stage__title-ar">ناضج</p>
          <p class="ladder-stage__title-en latin">Mature</p>
          <p class="ladder-stage__desc">إثبات إغلاق حلقة التعلّم — تكرار واحد على أقلّ من تغذية راجعة حقيقية.</p>
        </li>
        <li class="ladder-stage ladder-stage--reference">
          <span class="ladder-stage__step latin" aria-hidden="true">04</span>
          <span class="ladder-stage__icon" aria-hidden="true">🌲</span>
          <p class="ladder-stage__title-ar">مرجعي</p>
          <p class="ladder-stage__title-en latin">Reference</p>
          <p class="ladder-stage__desc">مرجع كامل: فيديو شرح بالعربية + مساعد GPT/Claude مخصّص + توافق Termux.</p>
        </li>
      </ol>

      <div class="ladder-status">
        <p class="ladder-status__now">
          الحالة الراهنة: {counts.mveComplete} 🌿 · {counts.mvePartial} 🌱 · {counts.planned} ⏳
        </p>
        <p class="ladder-status__target latin">
          <small>V1 target — 3 🌿 MVE-complete + 2 🌱 MVE-partial</small>
        </p>
      </div>
    </div>
  </section>

  <!-- ── Skills ──────────────────────────────────────────────────────── -->
  <section id="skills" class="skills">
    <div class="container">
      <!-- Core path: 3 skills MVE-complete cibles = main curriculum -->
      <div class="prose">
        <h2>المسار الأساسيّ · <span class="latin">Core path</span></h2>
        <p class="muted">
          ٣ مهارات متدرّجة من البيئة إلى المنتج المنشور. كلّ واحدة تفترض أنّ سابقتها مثبّتة.
        </p>
      </div>

      <div class="skills-grid skills-grid--core">
        {coreSkills.map(skill => (
          <SkillCard
            number={skill.number}
            slug={skill.slug}
            title_ar={skill.title_ar}
            description_ar={skill.description_ar}
            est_runtime_min={skill.est_runtime_min}
            maturity={skill.maturity}
            variant="core"
          />
        ))}
      </div>

      <!-- Extensions: 2 skills MVE-partial cibles = optional add-ons -->
      <div class="prose extensions-intro">
        <h3 class="extensions-title">
          إثراءات <span class="latin extensions-suffix">· Extensions</span>
        </h3>
        <p class="muted extensions-blurb">
          مهارات متخصّصة تبني على المسار الأساسيّ. اختياريّة، تُفتح عند الحاجة.
        </p>
      </div>

      <div class="skills-grid skills-grid--ext">
        {extensionSkills.map(skill => (
          <SkillCard
            number={skill.number}
            slug={skill.slug}
            title_ar={skill.title_ar}
            description_ar={skill.description_ar}
            est_runtime_min={skill.est_runtime_min}
            maturity={skill.maturity}
            variant="ext"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Audience ───────────────────────────────────────────────────── -->
  <section class="audience">
    <div class="container prose">
      <h2>لمن نبني؟</h2>
      <ul class="audience-list">
        <li>
          <strong>المطوّرون العرب</strong> الذين يجدون أنفسهم مقصيّين من الذكاء الاصطناعي الوكيل لأنّ المحتوى كلّه بالإنجليزية أو الفرنسية. المغرب، الجزائر، تونس، مصر، الشام، الخليج، والمغتربون.
        </li>
        <li>
          <strong>الممارسون ثنائيّو اللغة</strong> الذين يفضّلون التعلّم بالعربية لأسباب ثقافية وتربوية.
        </li>
        <li>
          <strong>المؤسّسات التعليمية</strong> في المنطقة (المدارس الخاصّة، البوتكامب، المدرّبون المحلّيون) الذين يحتاجون منهجًا عربيًا أصيلًا للذكاء الاصطناعي الوكيل.
        </li>
      </ul>

      <div class="mobile-note">
        <p class="muted latin">
          <small>📱 Mobile-first / low-spec friendly. Each skill declares whether it works on Android Termux,
          online IDEs (StackBlitz, Replit, Codespaces), or requires a local terminal.
          We don't assume Western dev setup.</small>
        </p>
      </div>
    </div>
  </section>

  <!-- ── Request a skill ─────────────────────────────────────────────── -->
  <RequestSkill />
  </main>

  <!-- ── Footer ──────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <p class="ar-script footer-mark">AI&nbsp;علّمني</p>
          <p class="muted latin"><small>Alimni AI · Arabic AI Engineering Academy</small></p>
        </div>

        <div class="footer-links latin">
          <a href="https://github.com/alimni-ai/skills" target="_blank" rel="noopener">GitHub</a>
          <a href="https://t.me/alimni_ar" target="_blank" rel="noopener">Telegram</a>
          <a href="https://x.com/alimni_ai" target="_blank" rel="noopener">X</a>
          <a href="https://linkedin.com/company/alimni-ai" target="_blank" rel="noopener">LinkedIn</a>
          <a href="mailto:hello@alimni-ai.com">hello@alimni-ai.com</a>
        </div>
      </div>

      <hr class="divider" />

      <p class="muted latin footer-credits">
        <small>
          © 2026 HDØZ AI · Licensed under Apache-2.0 for skill content ·
          "AI علّمني" calligraphy and the Alimni AI name are protected and reserved trademarks.
        </small>
      </p>
    </div>
  </footer>

  <style>
    /* ── Hero ────────────────────────────────────────────────────────── */
    .hero {
      padding-block: var(--s-3xl) var(--s-2xl);
      text-align: center;
    }
    /* No `align-items: center` here: it would shrink children to intrinsic
       content width and overflow the viewport on long Latin sentences.
       Children stretch to container width; AR paragraphs inherit text-align:
       center from `.hero`, while `.latin` keeps its text-align: left. */
    .hero-inner {
      display: flex;
      flex-direction: column;
      gap: var(--s-md);
      max-width: 720px;
      margin-inline: auto;
    }
    .hero-cta { align-self: center; }

    /* Brand mark — AR-script master, Latin sub-mark discret */
    .brand-mark {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--s-xs);
      margin-block-end: var(--s-sm);
    }

    .hero-mark {
      /* Sized for "AI علّمني" wordmark — narrower min to fit 390px viewport */
      font-size: clamp(3.25rem, 11vw, 8rem);
      color: var(--accent);
      line-height: 1;
      letter-spacing: 0;
      max-width: 100%;
      /* AR diacritics need breathing room */
      padding-block-start: 0.05em;
    }

    .sub-mark {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--fg-muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      direction: ltr;
      display: inline-flex;
      align-items: center;
      gap: 0.6em;
    }

    .sub-mark-dot {
      color: var(--accent-dim);
      font-size: 1.2em;
      line-height: 1;
    }

    .hero-tagline-ar {
      font-size: clamp(1.15rem, 2.4vw, 1.5rem);
      color: var(--fg);
      font-weight: 400;
      max-width: 540px;
      margin-inline: auto;
    }

    .hero-sub-ar {
      color: var(--fg-muted);
      max-width: 560px;
      margin-inline: auto;
      font-size: 1.05rem;
    }

    .hero-cta {
      display: flex;
      gap: var(--s-md);
      flex-wrap: wrap;
      justify-content: center;
      margin-block-start: var(--s-md);
    }

    .btn-ghost { background: transparent; }

    /* ── Dopamine block C1 — proof of execution ─────────────────────── */
    .proof-block {
      margin-block: var(--s-lg) var(--s-sm);
      padding: var(--s-lg) var(--s-md);
      background: var(--bg-elevated);
      border: 1px solid var(--line-strong);
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      gap: var(--s-md);
      text-align: center;
    }

    .proof-label-ar {
      font-size: clamp(0.95rem, 2vw, 1.05rem);
      color: var(--fg);
    }

    .proof-label-en {
      display: inline;
      color: var(--fg-muted);
      font-size: 0.8rem;
      padding-inline-start: 0.4em;
      unicode-bidi: isolate;
    }

    .proof-flow {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: var(--s-sm);
      direction: rtl;
    }

    .proof-step {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.8rem;
      background: var(--bg-card);
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      font-size: 0.9rem;
      color: var(--fg);
    }

    .proof-step.is-published {
      border-color: var(--accent-dim);
      color: var(--accent);
    }

    .proof-step-icon { font-size: 0.95rem; line-height: 1; }
    .proof-step-en {
      color: var(--fg-muted);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      text-transform: lowercase;
    }

    .proof-arrow {
      color: var(--accent-dim);
      font-family: var(--font-mono);
      font-size: 1rem;
      line-height: 1;
    }

    .proof-terminal {
      background: var(--bg);
      border: 1px solid var(--line);
      border-inline-start: 2px solid var(--accent);
      border-radius: 6px;
      padding: var(--s-md);
      margin-block-start: var(--s-xs);
      font-size: 0.78rem;
      line-height: 1.7;
      direction: ltr;
      text-align: left;
      overflow-x: auto;
      white-space: pre;
      color: var(--fg);
    }

    .proof-terminal code {
      background: transparent;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }

    .t-prompt   { color: var(--accent-dim); padding-inline-end: 0.5em; }
    .t-ok       { color: var(--accent); padding-inline-end: 0.4em; }
    .t-arrow    { color: var(--accent); padding-inline-end: 0.4em; }
    .t-token    { color: var(--accent-bright); }
    .t-muted    { color: var(--fg-muted); }

    /* ── Why ──────────────────────────────────────────────────────────── */
    .why p:first-of-type { font-size: 1.1rem; }

    .why-prose { display: flex; flex-direction: column; gap: var(--s-md); }
    .why-prose p { margin: 0; }

    /* Standalone aside — "الترجمة وحدها ليست ميزة." / "Translation alone..." */
    .why-aside {
      font-style: italic;
      color: var(--accent);
      font-size: 1.05rem;
      padding-block: var(--s-xs);
    }

    /* Edge list — "ميزة علّمني هي:" / "Alimni AI's edge is..." */
    .why-edge-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .why-edge-list li {
      position: relative;
      padding-inline-start: 1.2rem;
      color: var(--fg);
      line-height: 1.6;
    }

    .why-edge-list li::before {
      content: "→";
      position: absolute;
      inset-inline-start: 0;
      color: var(--accent-dim);
      font-family: var(--font-mono);
      /* In RTL, inline-start is the right edge; the arrow naturally faces inward.
         In LTR (.why-en), inline-start is the left edge; same visual logic. */
    }

    /* Closing emphasis */
    .why-closing {
      padding-inline-start: var(--s-md);
      border-inline-start: 2px solid var(--accent-dim);
      font-size: 1.05rem;
      margin-block-start: var(--s-xs);
    }

    .why-closing strong { color: var(--accent-bright); }

    /* EN secondary block — wraps the bilingual mirror, desktop-only via .hide-on-mobile */
    .why-en {
      margin-block-start: var(--s-xl);
      padding-block-start: var(--s-md);
      border-block-start: 1px dashed var(--line);
      display: flex;
      flex-direction: column;
      gap: var(--s-sm);
      font-size: 0.85rem;
    }

    .why-en .why-aside { font-size: 0.9rem; }
    .why-en .why-closing { font-size: 0.9rem; }

    /* ── Ladder ──────────────────────────────────────────────────────── */
    /* Card IS the stage. No nested pill badge. Vertical, centered layout. */
    .ladder-grid {
      list-style: none;
      padding: 0;
      margin-block: var(--s-xl);
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--s-md);
    }
    @media (min-width: 700px) {
      .ladder-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 1000px) {
      .ladder-grid { grid-template-columns: repeat(4, 1fr); }
    }

    .ladder-stage {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--s-xs);
      padding: var(--s-lg) var(--s-md);
      background: var(--bg-card);
      border: 1px solid var(--line);
      border-radius: 8px;
      text-align: center;
    }

    /* Step number — subtle corner marker, RTL-aware via inset-inline-end */
    .ladder-stage__step {
      position: absolute;
      inset-block-start: var(--s-sm);
      inset-inline-end: var(--s-md);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--fg-muted);
      letter-spacing: 0.1em;
    }

    .ladder-stage__icon {
      font-size: 2.5rem;
      line-height: 1;
      margin-block-start: var(--s-sm);
      margin-block-end: var(--s-xs);
    }

    .ladder-stage__title-ar {
      font-family: var(--font-ar);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--fg);
      margin: 0;
    }

    .ladder-stage__title-en {
      font-size: 0.72rem;
      color: var(--fg-muted);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-align: center; /* override .latin's text-align: left */
      margin: 0;
    }

    .ladder-stage__desc {
      font-size: 0.9rem;
      line-height: 1.65;
      color: var(--fg-muted);
      margin-block-start: var(--s-sm);
      padding-block-start: var(--s-md);
      border-block-start: 1px solid var(--line);
      width: 100%;
    }

    /* Progression accent — top border darkens through the stages */
    .ladder-stage--mve-partial  { border-block-start: 2px solid var(--line-strong); }
    .ladder-stage--mve-complete { border-block-start: 2px solid var(--accent-dim); }
    .ladder-stage--mature       { border-block-start: 2px solid var(--accent); }
    .ladder-stage--reference {
      border-block-start: 2px solid var(--accent-bright);
      background: linear-gradient(180deg, rgba(212, 165, 116, 0.06) 0%, var(--bg-card) 35%);
    }

    .ladder-status {
      margin-block-start: var(--s-lg);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--s-xs);
    }

    .ladder-status__now {
      font-size: 0.95rem;
      color: var(--fg-muted);
    }

    .ladder-status__target {
      direction: ltr;
      text-align: center;
      color: var(--fg-muted);
    }

    /* ── Skills ──────────────────────────────────────────────────────── */
    .skills-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--s-md);
      margin-block-start: var(--s-xl);
    }

    /* Core path — main curriculum, large cards */
    .skills-grid--core { gap: var(--s-md); }

    @media (min-width: 700px) {
      .skills-grid--core { grid-template-columns: repeat(3, 1fr); }
    }

    /* Extensions — visually secondary: smaller, denser, lower contrast */
    .skills-grid--ext {
      margin-block-start: var(--s-md);
      gap: var(--s-md);
    }

    @media (min-width: 700px) {
      .skills-grid--ext { grid-template-columns: repeat(2, 1fr); }
    }

    @media (min-width: 1000px) {
      .skills-grid--ext {
        grid-template-columns: repeat(2, 1fr);
        max-width: 760px;
        margin-inline: auto;
      }
    }

    .extensions-intro {
      margin-block-start: var(--s-2xl);
      padding-block-start: var(--s-lg);
      border-block-start: 1px dashed var(--line);
    }

    .extensions-title {
      font-size: 1.3rem;
      font-weight: 500;
      color: var(--fg-muted);
      margin-block-end: var(--s-xs);
    }

    .extensions-suffix {
      color: var(--fg-muted);
      font-size: 0.85rem;
      letter-spacing: 0.05em;
    }

    .extensions-blurb { font-size: 0.95rem; }

    /* ── Audience ── */
    .audience-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--s-md);
    }
    .audience-list li {
      padding: var(--s-md);
      background: var(--bg-card);
      border: 1px solid var(--line);
      border-radius: 6px;
      line-height: 1.7;
    }

    .mobile-note {
      margin-block-start: var(--s-lg);
      padding: var(--s-md);
      background: var(--bg-elevated);
      border: 1px dashed var(--line-strong);
      border-radius: 6px;
    }

    /* ── Footer ── */
    .footer {
      padding-block: var(--s-2xl);
      background: var(--bg-elevated);
      border-block-start: 1px solid var(--line);
    }

    .footer-grid {
      display: flex;
      flex-direction: column;
      gap: var(--s-md);
      align-items: flex-start;
    }
    @media (min-width: 700px) {
      .footer-grid { flex-direction: row; justify-content: space-between; align-items: center; }
    }

    .footer-mark { font-size: 2rem; color: var(--accent); margin-block-end: var(--s-xs); }

    .footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: var(--s-md);
      direction: ltr;
    }

    .footer-credits { direction: ltr; text-align: center; margin-block-start: var(--s-md); }

    /* ── Mobile fixes ────────────────────────────────────────────────── */
    @media (max-width: 540px) {
      .hero { padding-block: var(--s-2xl) var(--s-xl); }
      .hero-tagline-ar { font-size: 1.05rem; }
      .hero-sub-ar { font-size: 0.95rem; }

      .proof-block { padding: var(--s-md) var(--s-sm); gap: var(--s-sm); }
      .proof-flow { gap: 0.35rem; }
      .proof-step { padding: 0.25rem 0.55rem; font-size: 0.8rem; }
      .proof-step-en { display: none; }
      .proof-terminal { font-size: 0.7rem; padding: var(--s-sm); line-height: 1.6; }

      .extensions-intro { margin-block-start: var(--s-xl); }

      /* Force-hide the EN secondary block on mobile. The .hide-on-mobile global
         utility loses specificity vs the scoped .why-en `display: flex` rule. */
      .why-en { display: none; }
    }
  </style>
</BaseLayout>
