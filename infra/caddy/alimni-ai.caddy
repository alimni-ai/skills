# ──────────────────────────────────────────────────────────────────────────────
# Alimni AI — Arabic AI Engineering Academy
# Domain: alimni-ai.com (single-track hosting from W0, spec §9 revised 2026-05-07)
# Stage: V1 placeholder (W1 brand-lock). Real landing replaces this at W4 Step 4.6.
# ──────────────────────────────────────────────────────────────────────────────

www.alimni-ai.com {
    redir https://alimni-ai.com{uri} permanent
}

alimni-ai.com {
    root * /var/www/alimni-ai

    # CF-only access — anti-phishing / anti-bypass (matches TENERE/RIMAYA/BCF pattern,
    # per memory feedback_deployment_security_rules.md).
    @not_cloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    respond @not_cloudflare 403 {
        body "Direct access denied. Use https://alimni-ai.com"
        close
    }

    encode zstd gzip
    file_server

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
        # Placeholder W1 — noindex until real landing ships at W4
        X-Robots-Tag "noindex, nofollow"
        Cache-Control "public, max-age=300, must-revalidate"
        -Server
    }

    log {
        output file /var/log/caddy/alimni-ai.log
        format json
    }
}
