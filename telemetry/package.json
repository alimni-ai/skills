{
  "name": "alimni-ai-telemetry",
  "version": "0.1.0",
  "private": true,
  "description": "Anonymous opt-in completion ping endpoint for Alimni AI skills",
  "type": "module",
  "main": "server.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test tests/*.test.js",
    "schema:apply": "psql \"$ALIMNI_TELEMETRY_DATABASE_URL\" -f schema.sql"
  },
  "dependencies": {
    "express": "4.21.2",
    "pg": "8.13.1",
    "dotenv": "16.4.5"
  }
}
