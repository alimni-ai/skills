# ──────────────────────────────────────────────────────────────────────────────
# Alimni AI — telemetry endpoint
# Domain: ping.alimni-ai.com
# Stage: V2-prep (deploy executes at W6 per implementation plan)
#
# This file lives at /etc/caddy/conf.d/ping.alimni-ai.caddy on gestion (per
# the conf.d isolation pattern, memory feedback_caddy_isolation_per_tenant).
# Drop-in: appending here cannot break other tenants.
# ──────────────────────────────────────────────────────────────────────────────

ping.alimni-ai.com {
    # CF-only access (anti-phishing, matches TENERE/RIMAYA/BCF/Alimni-landing pattern)
    @not_cloudflare not remote_ip 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    respond @not_cloudflare 403 {
        body "Direct access denied. Use https://ping.alimni-ai.com"
        close
    }

    # Reverse-proxy to the local telemetry server on port 4011
    reverse_proxy 127.0.0.1:4011 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up CF-IPCountry {http.request.header.CF-IPCountry}
    }

    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        # noindex — this is an API endpoint, not a page
        X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
        -Server
    }

    log {
        output file /var/log/caddy/ping.alimni-ai.log
        format json
    }
}
