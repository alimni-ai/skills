# Alimni AI telemetry — environment variables (copy to .env, never commit .env)
#
# The DATABASE_URL points to the dedicated Postgres role + DB created by
# scripts/setup-postgres.sh. The role has INSERT-only access to
# skill_completions and cannot connect to other databases on the gestion
# Postgres cluster (cross-app CONNECT denied by setup-postgres.sh).

ALIMNI_TELEMETRY_DATABASE_URL=postgresql://alimni_telemetry_app:CHANGEME@127.0.0.1:5432/alimni_telemetry

# Port the Express server listens on (Caddy reverse-proxies to this on gestion)
PORT=4011

# production | development
NODE_ENV=development
